# Environment Variables for NAMOH Institute
# Copy this file to .env for local development.
# Set these in Vercel Dashboard → Project Settings → Environment Variables for production.
#
# SECURITY: These variables are SERVER-SIDE ONLY.
# They are NEVER sent to the browser. The browser only calls /api/chat,
# which runs on Vercel's servers where these keys are securely stored.

# ---------------------------------------------------------
# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
# Or from Google Cloud Console → APIs & Services → Credentials
# NEVER put this in any frontend JS file!
# ---------------------------------------------------------
GOOGLE_API_KEY=AIzaSy_YOUR_ACTUAL_KEY_HERE

# ---------------------------------------------------------
# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Cluster → Connect → Drivers
# ---------------------------------------------------------
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.XXXXX.mongodb.net/namoh?retryWrites=true&w=majority

# ---------------------------------------------------------
# Admin secret token — protects GET /api/leads
# Generate: openssl rand -hex 32
# ---------------------------------------------------------
ADMIN_SECRET=your-strong-random-secret-here
